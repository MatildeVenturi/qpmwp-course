   "source": [
    "\n",
    "w_minvar = pd.Series(minvar.results[\"weights\"], index=constraints.ids)\n",
    "\n",
    "Sigma = covariance.matrix.values if hasattr(covariance.matrix, \"values\") else np.asarray(covariance.matrix)\n",
    "mu = returns.mean().values\n",
    "w1 = w_minvar.values\n",
    "\n",
    "ret_minvar = float(mu.T @ w1)\n",
    "var_minvar = float(w1.T @ Sigma @ w1)\n",
    "\n",
    "comparison = []\n",
    "\n",
    "for solver, w_mv in weights_dict.items():\n",
    "    if w_mv is None:\n",
    "        continue\n",
    "\n",
    "    w2 = w_mv.values\n",
    "\n",
    "    comparison.append({\n",
    "        \"solver\": solver,\n",
    "        \"minvar_return\": ret_minvar,\n",
    "        \"mv_return\": float(mu.T @ w2),\n",
    "        \"minvar_variance\": var_minvar,\n",
    "        \"mv_variance\": float(w2.T @ Sigma @ w2),\n",
    "        \"weight_diff_norm\": float(np.linalg.norm(w2 - w1))\n",
    "    })\n",
    "\n",
    "comparison_df = pd.DataFrame(comparison).set_index(\"solver\")\n",
    "\n",
    "print(comparison_df)\n",
    "\n",
    "weights_compare_all = {}\n",
    "\n",
    "for solver, w_mv in weights_dict.items():\n",
    "    if w_mv is None:\n",
    "        continue\n",
    "\n",
    "    tmp = pd.concat(\n",
    "        [\n",
    "            w_minvar.rename(\"MinVariance\"),\n",
    "            w_mv.rename(f\"MeanVariance_{solver}\")\n",
    "        ],\n",
    "        axis=1\n",
    "    )\n",
    "    tmp[\"diff\"] = tmp.iloc[:, 1] - tmp.iloc[:, 0]\n",
    "    weights_compare_all[solver] = tmp\n",
    "\n",
    "solvers_to_check = [\"osqp\", \"cvxopt\", \"qpalm\", \"quadprog\", \"daqp\"]\n",
    "\n",
    "for s in solvers_to_check:\n",
    "    if s in weights_compare_all:\n",
    "        print(f\"\\n{s.upper()} \")\n",
    "        print(weights_compare_all[s])\n",
    "    else:\n",
    "        print(f\"\\n{s.upper()} \")\n",
    "        print(\"No solution available\")\n"
   ]
  }
