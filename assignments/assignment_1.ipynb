   "source": [
    "# ==============================\n",
    "# Clear comparison: MinVariance benchmark + MeanVariance differences\n",
    "# ==============================\n",
    "\n",
    "# 1. Build MinVariance weights\n",
    "w_minvar = pd.Series(minvar.results[\"weights\"], index=constraints.ids, name=\"MinVariance\")\n",
    "\n",
    "# 2. Extract moments\n",
    "Sigma = covariance.matrix.values if hasattr(covariance.matrix, \"values\") else np.asarray(covariance.matrix)\n",
    "mu = returns.mean().values\n",
    "\n",
    "# 3. Helper function\n",
    "def portfolio_stats(w, mu, Sigma):\n",
    "    w = np.asarray(w, dtype=float)\n",
    "    exp_return = float(w @ mu)\n",
    "    variance = float(w @ Sigma @ w)\n",
    "    volatility = float(np.sqrt(variance))\n",
    "    return exp_return, variance, volatility\n",
    "\n",
    "# 4. MinVariance benchmark statistics\n",
    "minvar_ret, minvar_var, minvar_vol = portfolio_stats(w_minvar.values, mu, Sigma)\n",
    "\n",
    "benchmark_df = pd.DataFrame({\n",
    "    \"Expected Return\": [minvar_ret],\n",
    "    \"Variance\": [minvar_var],\n",
    "    \"Volatility\": [minvar_vol]\n",
    "}, index=[\"Analytical MinVariance\"])\n",
    "\n",
    "# 5. Compare each MeanVariance solution against the benchmark\n",
    "comparison_rows = []\n",
    "weights_comparison = {}\n",
    "\n",
    "for solver, w_mv in weights_dict.items():\n",
    "    if w_mv is None:\n",
    "        continue\n",
    "\n",
    "    if not isinstance(w_mv, pd.Series):\n",
    "        w_mv = pd.Series(w_mv, index=constraints.ids, name=f\"MeanVariance_{solver}\")\n",
    "    else:\n",
    "        w_mv = w_mv.reindex(constraints.ids)\n",
    "\n",
    "    mv_ret, mv_var, mv_vol = portfolio_stats(w_mv.values, mu, Sigma)\n",
    "\n",
    "    comparison_rows.append({\n",
    "        \"Solver\": solver.upper(),\n",
    "        \"MV Return\": mv_ret,\n",
    "        \"MV Variance\": mv_var,\n",
    "        \"MV Volatility\": mv_vol,\n",
    "        \"Δ Return (MV - MinVar)\": mv_ret - minvar_ret,\n",
    "        \"Δ Variance (MV - MinVar)\": mv_var - minvar_var,\n",
    "        \"Δ Volatility (MV - MinVar)\": mv_vol - minvar_vol,\n",
    "        \"Weight Distance (L2)\": float(np.linalg.norm(w_mv.values - w_minvar.values)),\n",
    "        \"Max Absolute Weight Diff\": float(np.max(np.abs(w_mv.values - w_minvar.values))),\n",
    "    })\n",
    "\n",
    "    weights_comparison[solver] = pd.DataFrame({\n",
    "        \"MinVariance\": w_minvar,\n",
    "        f\"MeanVariance_{solver.upper()}\": w_mv,\n",
    "        \"Difference (MV - MinVar)\": w_mv - w_minvar\n",
    "    })\n",
    "\n",
    "comparison_df = (\n",
    "    pd.DataFrame(comparison_rows)\n",
    "    .set_index(\"Solver\")\n",
    "    .sort_values(\"Weight Distance (L2)\")\n",
    ")\n",
    "\n",
    "print(\"Benchmark portfolio:\")\n",
    "display(benchmark_df.round(6))\n",
    "\n",
    "print(\"MeanVariance portfolios compared to the MinVariance benchmark:\")\n",
    "display(comparison_df.round(6))\n",
    "\n",
    "# 6. Show detailed weights for the closest MeanVariance solution\n",
    "# To check the difference with other solvers, you can change the index in weights_comparison to the desired solver (e.g., \"OSQP\", \"CVXOPT\", etc.)\n",
    "if not comparison_df.empty:\n",
    "    reference_solver = comparison_df.index[0].lower()\n",
    "    print(f\"\\nDetailed weight comparison for solver: {reference_solver.upper()}\")\n",
    "    display(weights_comparison[reference_solver].round(6))"
   ]
