   "source": [
    "# 2. Create a constraints object with just a budget constraint\n",
    "constraints = Constraints(ids=returns.columns.tolist())\n",
    "constraints.add_budget(rhs=1, sense=\"=\")\n",
    "\n",
    "covariance = Covariance(method='pearson')\n",
    "covariance.estimate(X=returns, inplace=True)\n",
    "\n",
    "# 3. Instantiate the MinVariance class\n",
    "minvar = MinVariance(\n",
    "    constraints=constraints,\n",
    "    covariance=covariance,\n",
    "    solver_name=\"analytical\",\n",
    ")\n",
    "\n",
    "# 4. Prepare the optimization data and prepare the optimization problem\n",
    "optimization_data = OptimizationData(sigma=covariance.matrix)\n",
    "optimization_data[\"return_series\"] = returns\n",
    "\n",
    "# 5. Solve the optimization problem and print the weights\n",
    "minvar.set_objective(optimization_data=optimization_data)\n",
    "minvar.objective.coefficients\n",
    "\n",
    "minvar.solve()\n",
    "print(minvar.results)\n",
    "\n",
    "# 6. Show metrics and weights\n",
    "metric_keys = [\n",
    "    \"solution_found\",\n",
    "    \"objective\",\n",
    "    \"primal_residual\",\n",
    "    \"dual_residual\",\n",
    "    \"duality_gap\",\n",
    "    \"runtime\",\n",
    "    \"error\",\n",
    "]\n",
    "\n",
    "metrics = {k: minvar.results.get(k, None) for k in metric_keys}\n",
    "print(\"Metrics:\")\n",
    "display(pd.DataFrame.from_dict(metrics, orient=\"index\", columns=[\"Value\"]))\n",
    "\n",
    "print(\"Weights:\")\n",
    "display(pd.DataFrame(minvar.results[\"weights\"], index=constraints.ids, columns=[\"Weight\"]))"
   ]
  },
