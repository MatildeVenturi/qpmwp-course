    "## 2. Analytical Solution to Minimum-Variance Problem\n",
    "\n",
    "(5 points)\n",
    "\n",
    "- Create a `MinVariance` class that follows the structure of the `MeanVariance` class.\n",
    "- Implement the `solve` method in `MinVariance` such that if `solver_name = 'analytical'`, the analytical solution is computed and stored within the object (if such a solution exists). If not, call the `solve` method from the parent class.\n",
    "- Create a `Constraints` object by injecting the same ids as in part 1.b) and add a budget constraint.\n",
    "- Instantiate a `MinVariance` object by setting `solver_name = 'analytical'` and passing instances of `Constraints` and `Covariance` as arguments.\n",
    "- Create an `OptimizationData` object that contains an element `return_series`, which consists of the synthetic data generated in part 1.a).\n",
    "- Solve the optimization problem using the created `MinVariance` object and compare the results to those obtained in part 1.c)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 1. Define class MinVariance\n",
    "class MinVariance(Optimization):\n",
    "    def __init__(self,\n",
    "                 constraints: Constraints,\n",
    "                 covariance: Optional[Covariance] = None,\n",
    "                 **kwargs):\n",
    "        super().__init__(constraints=constraints, **kwargs)\n",
    "        self.covariance = Covariance() if covariance is None else covariance\n",
    "\n",
    "    def set_objective(self, optimization_data: OptimizationData) -> None:\n",
    "        X = optimization_data['return_series']\n",
    "        Sigma = self.covariance.estimate(X=X, inplace=False)\n",
    "        n_assets = X.shape[1]\n",
    "\n",
    "        self.objective = Objective(\n",
    "            q = np.zeros(n_assets),\n",
    "            P = 2* Sigma,\n",
    "        )\n",
    "        return None\n",
    "\n",
    "    # ==============================\n",
    "    # Helper Functions for Analytical Solution\n",
    "    # ==============================\n",
    "\n",
    "    @staticmethod\n",
    "    def _to_numpy(x):\n",
    "        \"\"\"Convert pandas / array-like objects to NumPy arrays.\"\"\"\n",
    "        if hasattr(x, \"to_numpy\"):\n",
    "            x = x.to_numpy()\n",
    "        return np.asarray(x, dtype=float)\n",
    "    \n",
    "    # Helper function to extract Sigma from the quadratic objective\n",
    "    def _extract_sigma(self) -> np.ndarray:\n",
    "        \"\"\"Recover Sigma from the quadratic objective P = 2 * Sigma.\"\"\"\n",
    "        if self.objective is None:\n",
    "            raise ValueError(\"Objective is not set. Call set_objective() first.\")\n",
    "\n",
    "        coeffs = self.objective.coefficients\n",
    "        if \"P\" not in coeffs:\n",
    "            raise ValueError(\"Objective must contain 'P'.\")\n",
    "\n",
    "        P = self._to_numpy(coeffs[\"P\"])\n",
    "        Sigma = 0.5 * P\n",
    "        return Sigma\n",
    "\n",
    "    def _extract_objective_matrices(self) -> tuple[np.ndarray, np.ndarray]:\n",
    "        \"\"\"Extract P and q from the quadratic objective.\"\"\"\n",
    "        if self.objective is None:\n",
    "            raise ValueError(\"Objective is not set. Call set_objective() first.\")\n",
    "\n",
    "        coeffs = self.objective.coefficients\n",
    "        P = self._to_numpy(coeffs[\"P\"])\n",
    "        q = self._to_numpy(coeffs.get(\"q\", np.zeros(P.shape[0]))).reshape(-1)\n",
    "        return P, q\n",
    "\n",
    "    # Helper function to extract equality constraints A and b\n",
    "    def _extract_equality_constraints(self) -> tuple[np.ndarray, np.ndarray]:\n",
    "        \"\"\"\n",
    "        Extract equality constraints A x = b.\n",
    "\n",
    "        The analytical minimum-variance formula is valid only for\n",
    "        equality-constrained problems.\n",
    "        \"\"\"\n",
    "        GhAb = self.constraints.to_GhAb()\n",
    "        A = GhAb.get(\"A\", None)\n",
    "        b = GhAb.get(\"b\", None)\n",
    "        G = GhAb.get(\"G\", None)\n",
    "\n",
    "        if A is None or b is None:\n",
    "            raise ValueError(\n",
    "                \"Analytical solution requires equality constraints A x = b.\"\n",
    "            )\n",
    "\n",
    "        if G is not None and len(G) > 0:\n",
    "            raise ValueError(\n",
    "                \"Analytical solution is only implemented for equality constraints.\"\n",
    "            )\n",
    "\n",
    "        A = self._to_numpy(A)\n",
    "        b = self._to_numpy(b).reshape(-1, 1)\n",
    "        return A, b\n",
    "\n",
    "    @staticmethod\n",
    "    def _compute_primal_residual(A: np.ndarray, x: np.ndarray, b: np.ndarray) -> float:\n",
    "        \"\"\"Infinity norm of equality-constraint violation.\"\"\"\n",
    "        return float(np.max(np.abs(A @ x - b)))\n",
    "    \n",
    "    @staticmethod\n",
    "    def _compute_lambda(P: np.ndarray, A: np.ndarray, b: np.ndarray) -> np.ndarray:\n",
    "        \"\"\"\n",
    "        Recover equality multipliers from KKT conditions for\n",
    "\n",
    "            min 1/2 x'Px + q'x\n",
    "            s.t. A x = b\n",
    "\n",
    "        with q = 0 in this problem.\n",
    "        \"\"\"\n",
    "        P_inv_AT = np.linalg.solve(P, A.T)\n",
    "        lam = np.linalg.solve(A @ P_inv_AT, -b)\n",
    "        return np.asarray(lam, dtype=float).reshape(-1)\n",
    "\n",
    "    @staticmethod\n",
    "    def _compute_dual_residual(P: np.ndarray,\n",
    "                               q: np.ndarray,\n",
    "                               A: np.ndarray,\n",
    "                               x: np.ndarray,\n",
    "                               lam: np.ndarray) -> float:\n",
    "        \"\"\"Infinity norm of stationarity residual.\"\"\"\n",
    "        return float(np.max(np.abs(P @ x + q + A.T @ lam)))\n",
    "\n",
    "    @staticmethod\n",
    "    def _compute_duality_gap(P: np.ndarray,\n",
    "                             q: np.ndarray,\n",
    "                             A: np.ndarray,\n",
    "                             b: np.ndarray,\n",
    "                             x: np.ndarray,\n",
    "                             lam: np.ndarray) -> float:\n",
    "        \"\"\"\n",
    "        Duality gap for equality-constrained QP.\n",
    "\n",
    "        Primal:\n",
    "            1/2 x'Px + q'x\n",
    "\n",
    "        Dual:\n",
    "            -1/2 (q + A'lam)' P^{-1} (q + A'lam) - b'lam\n",
    "        \"\"\"\n",
    "        P = np.asarray(P, dtype=float)\n",
    "        q = np.asarray(q, dtype=float).reshape(-1)\n",
    "        b = np.asarray(b, dtype=float).reshape(-1)\n",
    "        x = np.asarray(x, dtype=float).reshape(-1)\n",
    "        lam = np.asarray(lam, dtype=float).reshape(-1)\n",
    "\n",
    "        primal = 0.5 * x @ P @ x + q @ x\n",
    "        y = q + A.T @ lam\n",
    "        dual = -0.5 * (y @ np.linalg.solve(P, y)) - (b @ lam)\n",
    "\n",
    "        return float(primal - dual)\n",
    "    \n",
    "    # ==============================\n",
    "    # Analytical Solution Function\n",
    "    # ==============================\n",
    "\n",
    "    def _solve_analytically(self) -> None:\n",
    "        \"\"\"\n",
    "        Solve the minimum-variance problem analytically using:\n",
    "\n",
    "            x* = Σ^{-1} A' (A Σ^{-1} A')^{-1} b\n",
    "        \"\"\"\n",
    "        t0 = time.perf_counter()\n",
    "\n",
    "        Sigma = self._extract_sigma()\n",
    "        P, q = self._extract_objective_matrices()\n",
    "        A, b = self._extract_equality_constraints()\n",
    "\n",
    "        # Step 1: compute Σ^{-1} A'\n",
    "        Sigma_inv_AT = np.linalg.solve(Sigma, A.T)\n",
    "\n",
    "        # Step 2: compute A Σ^{-1} A'\n",
    "        middle_matrix = A @ Sigma_inv_AT\n",
    "\n",
    "        # Step 3: compute (A Σ^{-1} A')^{-1} b\n",
    "        multiplier = np.linalg.solve(middle_matrix, b)\n",
    "\n",
    "        # Step 4: compute x*\n",
    "        x = Sigma_inv_AT @ multiplier\n",
    "        x = x.reshape(-1)\n",
    "\n",
    "        runtime = time.perf_counter() - t0\n",
    "\n",
    "        # KKT-based diagnostics\n",
    "        lam = self._compute_lambda(P=P, A=A, b=b)\n",
    "        objective = float(0.5 * x @ P @ x + q @ x)\n",
    "        primal_residual = self._compute_primal_residual(A=A, x=x, b=b)\n",
    "        dual_residual = self._compute_dual_residual(P=P, q=q, A=A, x=x, lam=lam)\n",
    "        duality_gap = self._compute_duality_gap(P=P, q=q, A=A, b=b, x=x, lam=lam)\n",
    "\n",
    "        # Store results with same structure as numerical solvers\n",
    "        self.results.update({\n",
    "            \"solution_found\": True,\n",
    "            \"weights\": x,\n",
    "            \"objective\": objective,\n",
    "            \"objective_value\": objective,   # optional, for backward compatibility\n",
    "            \"primal_residual\": primal_residual,\n",
    "            \"dual_residual\": dual_residual,\n",
    "            \"duality_gap\": duality_gap,\n",
    "            \"runtime\": runtime,\n",
    "            \"error\": None,\n",
    "        })\n",
    "    \n",
    "    # ==============================\n",
    "    # Optimizer Solve\n",
    "    # ==============================\n",
    "\n",
    "    def solve(self) -> None:\n",
    "        \"\"\"\n",
    "        Solve the optimization problem.\n",
    "\n",
    "        - If solver_name == 'analytical', use the closed-form solution.\n",
    "        - Otherwise, call the parent class solver.\n",
    "        \"\"\"\n",
    "        if self.params.get(\"solver_name\") != \"analytical\":\n",
    "            return super().solve()\n",
    "\n",
    "        self._solve_analytically()\n",
    "        return None\n"
   ]
  },
